# SigNoz local development environment overrides
#
# Copy this file to `.env` and adjust values as needed.
# `.env` is gitignored and loaded by `make go-run-community` via shell source.
# Any SIGNOZ_* variable set here overrides the Go binary defaults.

# --- Telemetry Store (ClickHouse) ---
# Your ClickHouse DSN. Change this if ClickHouse runs in a container
# with a different IP, e.g. tcp://172.15.0.3:9000
SIGNOZ_TELEMETRYSTORE_CLICKHOUSE_DSN=tcp://127.0.0.1:9000
SIGNOZ_TELEMETRYSTORE_CLICKHOUSE_CLUSTER=cluster
SIGNOZ_TELEMETRYSTORE_PROVIDER=clickhouse

# --- SQL Store ---
SIGNOZ_SQLSTORE_SQLITE_PATH=siginsight.db

# --- Web ---
# Set to true to serve embedded frontend on :8080 (requires `make js-build` first)
SIGNOZ_WEB_ENABLED=false

# --- Auth ---
SIGNOZ_TOKENIZER_JWT_SECRET=secret

# --- Alertmanager ---
SIGNOZ_ALERTMANAGER_PROVIDER=signoz

# --- Instrumentation ---
SIGNOZ_INSTRUMENTATION_LOGS_LEVEL=debug
